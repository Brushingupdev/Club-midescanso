<footer class="footer" id="footer">
    <div class="footer-glow"></div>

    <div class="footer-body">
        <!-- COL 1: Logo + info + redes -->
        <div class="footer-brand">
            <a href="#hero" class="footer-logo-wrap">
                <img
                    src="/img/logo.png"
                    alt="Mi Descanso logo"
                    class="footer-logo"
                />
            </a>
            <p class="footer-tagline">
                Tu escape campestre en el distrito de Ate. Gastronomía criolla,
                piscinas, shows en vivo y amplias áreas verdes para disfrutar y
                relajarse en familia.
            </p>

            <div class="footer-quick-info">
                <span class="fqi-item">
                    <i data-lucide="map-pin" class="fqi-icon"></i>
                    Asociación El Descanso, Ate 15479
                </span>
                <span class="fqi-item">
                    <i data-lucide="clock" class="fqi-icon"></i>
                    Mar – Dom · 9:00 AM – 6:00 PM
                </span>
                <span class="fqi-item">
                    <i data-lucide="phone" class="fqi-icon"></i>
                    +51 999 888 777
                </span>
            </div>

            <div class="footer-socials">
                <a href="#" aria-label="Instagram" class="social-btn">
                    <i data-lucide="instagram"></i>
                </a>
                <a href="#" aria-label="Facebook" class="social-btn">
                    <i data-lucide="facebook"></i>
                </a>
                <a href="#" aria-label="TikTok" class="social-btn">
                    <i data-lucide="music-2"></i>
                </a>
                <a href="#" aria-label="YouTube" class="social-btn">
                    <i data-lucide="youtube"></i>
                </a>
            </div>
        </div>

        <!-- COL 2: Servicios -->
        <nav class="footer-col">
            <h4 class="footer-col-title">Servicios</h4>
            <ul class="footer-links">
                <li><a href="#restaurante">Gastronomía Criolla</a></li>
                <li><a href="#piscinas">Club Acuático</a></li>
                <li><a href="#hospedaje">Bungalows</a></li>
                <li><a href="#shows">Shows & Eventos</a></li>
                <li><a href="#galeria">Galería</a></li>
                <li><a href="#contacto">Contacto</a></li>
            </ul>
        </nav>

        <!-- COL 3: Reserva CTA -->
        <div class="footer-cta-col">
            <h4 class="footer-col-title">¿Listos para visitarnos?</h4>
            <p class="footer-cta-desc">
                Reserva tu visita y asegura una experiencia inolvidable para
                toda la familia.
            </p>
            <a
                href="https://wa.me/51999888777?text=Hola%2C%20quiero%20reservar%20una%20visita%20a%20Mi%20Descanso.%20%C2%BFPodr%C3%ADan%20darme%20m%C3%A1s%20informaci%C3%B3n%3F"
                target="_blank"
                rel="noopener"
                class="footer-wa-btn"
            >
                <i data-lucide="message-circle"></i>
                Reservar por WhatsApp
            </a>
            <div class="footer-badge">
                <span class="badge-dot"></span>
                Atendemos Mar a Dom · 9AM – 6PM
            </div>
        </div>
    </div>

    <!-- BARRA INFERIOR -->
    <div class="footer-bottom">
        <p class="footer-copy">
            &copy; 2026 · <strong>Mi Descanso</strong> Resort Campestre · Todos los
            derechos reservados.
        </p>
        <p class="footer-credit">Ate · Lima · Perú</p>
    </div>
</footer>

<style>
    @reference "../styles/global.css";

    .footer {
        background: var(--color-forest-dark);
        color: var(--color-cream);
        position: relative;
        overflow: hidden;
        padding: clamp(50px, 6vw, 70px) clamp(24px, 5vw, 60px) 0;
    }

    .footer-glow {
        position: absolute;
        top: -20%;
        right: -8%;
        width: 45vw;
        height: 45vw;
        background: radial-gradient(
            circle,
            rgba(208, 123, 67, 0.06) 0%,
            transparent 65%
        );
        pointer-events: none;
    }

    /* ── GRID ── */
    .footer-body {
        position: relative;
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.7fr 1fr 1.2fr;
        gap: clamp(32px, 4vw, 60px);
        padding-bottom: clamp(30px, 5vw, 45px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        align-items: start;
    }

    /* ── COL 1 BRAND ── */
    .footer-brand {
        display: flex;
        flex-direction: column;
    }

    .footer-logo-wrap {
        display: inline-block;
        margin-bottom: 22px;
    }
    .footer-logo {
        height: 140px;
        width: auto;
        object-fit: contain;
    }

    .footer-tagline {
        font-size: 0.85rem;
        color: rgba(250, 247, 242, 0.48);
        line-height: 1.75;
        margin-bottom: 22px;
        max-width: 300px;
    }

    .footer-quick-info {
        display: flex;
        flex-direction: column;
        gap: 9px;
        margin-bottom: 26px;
    }
    .fqi-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.77rem;
        color: rgba(250, 247, 242, 0.48);
    }
    .fqi-icon {
        width: 12px;
        height: 12px;
        color: var(--color-copper);
        flex-shrink: 0;
    }

    .footer-socials {
        display: flex;
        gap: 10px;
    }
    .social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: rgba(255, 255, 255, 0.45);
        transition:
            background 0.25s,
            color 0.25s,
            border-color 0.25s,
            transform 0.25s;
    }
    .social-btn i {
        width: 15px;
        height: 15px;
    }
    .social-btn:hover {
        background: var(--color-copper);
        border-color: var(--color-copper);
        color: white;
        transform: translateY(-3px);
    }

    /* ── COL 2 SERVICIOS ── */
    .footer-col {
        display: flex;
        flex-direction: column;
        padding-top: 60px;
    }

    .footer-col-title {
        font-family: var(--font-body);
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.22em;
        color: var(--color-copper);
        margin-bottom: 24px;
    }

    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 13px;
    }
    .footer-links li a {
        font-size: 0.86rem;
        color: rgba(250, 247, 242, 0.48);
        text-decoration: none;
        transition:
            color 0.2s,
            padding-left 0.2s;
        display: inline-block;
    }
    .footer-links li a:hover {
        color: var(--color-cream);
        padding-left: 5px;
    }

    /* ── COL 3 CTA ── */
    .footer-cta-col {
        display: flex;
        flex-direction: column;
        padding-top: 60px;
    }

    .footer-cta-desc {
        font-size: 0.84rem;
        color: rgba(250, 247, 242, 0.45);
        line-height: 1.72;
        margin-bottom: 22px;
    }

    .footer-wa-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        align-self: flex-start;
        padding: 13px 24px;
        background: var(--color-copper);
        color: white;
        border-radius: 100px;
        font-family: var(--font-body);
        font-size: 0.76rem;
        font-weight: 600;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        text-decoration: none;
        transition:
            background 0.25s,
            transform 0.25s,
            box-shadow 0.25s;
        margin-bottom: 18px;
    }
    .footer-wa-btn i {
        width: 16px;
        height: 16px;
    }
    .footer-wa-btn:hover {
        background: #c2662e;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(208, 123, 67, 0.3);
    }

    .footer-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.7rem;
        color: rgba(250, 247, 242, 0.35);
    }
    .badge-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #4caf50;
        box-shadow: 0 0 0 3px rgba(76, 175, 80, 0.2);
        flex-shrink: 0;
        animation: pulse-green 2.5s ease infinite;
    }
    @keyframes pulse-green {
        0%,
        100% {
            box-shadow: 0 0 0 3px rgba(76, 175, 80, 0.2);
        }
        50% {
            box-shadow: 0 0 0 6px rgba(76, 175, 80, 0.08);
        }
    }

    /* ── BOTTOM BAR ── */
    .footer-bottom {
        position: relative;
        max-width: 1280px;
        margin: 0 auto;
        padding: 16px 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
    }
    .footer-copy {
        font-size: 0.72rem;
        color: rgba(250, 247, 242, 0.25);
        letter-spacing: 0.03em;
    }
    .footer-copy strong {
        color: rgba(250, 247, 242, 0.45);
        font-weight: 600;
    }
    .footer-credit {
        font-size: 0.68rem;
        color: rgba(250, 247, 242, 0.18);
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
        .footer-body {
            grid-template-columns: 1fr 1fr;
        }
        .footer-brand {
            grid-column: span 2;
        }
        .footer-col,
        .footer-cta-col {
            padding-top: 0;
        }
    }
    @media (max-width: 560px) {
        .footer-body {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .footer-brand {
            grid-column: span 1;
            align-items: center;
        }
        .footer-tagline {
            margin: 0 auto 22px;
        }
        .fqi-item {
            justify-content: center;
        }
        .footer-socials {
            justify-content: center;
        }
        .footer-cta-col {
            align-items: center;
        }
        .footer-wa-btn {
            align-self: center;
        }
        .footer-bottom {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
