<!-- MODAL CARTA VIRTUAL -->
<div
    class="fixed inset-0 w-full h-full z-[2000] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] menu-modal"
    id="menuModal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
>
    <div
        class="absolute inset-0 bg-[#132418e6] backdrop-blur-[10px]"
        id="menuOverlay"
    >
    </div>
    <div
        class="menu-modal-content bg-cream w-[90%] max-w-[800px] h-[85vh] rounded-[20px] relative z-[1] overflow-y-auto p-[60px] translate-y-[40px] transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]"
    >
        <button
            class="absolute top-[30px] right-[30px] bg-sand border-none w-[44px] h-[44px] rounded-full flex items-center justify-center text-forest cursor-pointer transition-all duration-300 hover:bg-copper hover:text-white hover:rotate-90"
            id="menuCloseBtn"
            aria-label="Cerrar carta"
        >
            <i aria-hidden="true" data-lucide="x"></i>
        </button>

        <div class="mb-[50px] border-b border-copper/30 pb-[30px]">
            <div
                class="subtitle-section justify-center text-copper before:bg-copper"
            >
                Nuestra Carta
            </div>
