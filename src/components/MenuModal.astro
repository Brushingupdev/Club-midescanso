<style>
    @reference "../styles/global.css";

    .menu-modal-content {
        box-shadow: var(--shadow-modal);
    }
    :global(.menu-modal.active) {
        @apply opacity-100 pointer-events-auto;
    }
    :global(.menu-modal.active .menu-modal-content) {
        @apply translate-y-0;
    }
</style>

<script>
    const btnOpenMenu = document.getElementById("btn-open-menu");
    const menuModal = document.getElementById("menuModal");
    const menuCloseBtn = document.getElementById("menuCloseBtn");
    const menuOverlay = document.getElementById("menuOverlay");

    function toggleModal(show: boolean) {
        if (show) {
            menuModal?.classList.add("active");
            document.body.style.overflow = "hidden";
        } else {
            menuModal?.classList.remove("active");
            document.body.style.overflow = "";
        }
    }

    if (btnOpenMenu) {
        btnOpenMenu.addEventListener("click", () => toggleModal(true));
    }
    if (menuCloseBtn) {
        menuCloseBtn.addEventListener("click", () => toggleModal(false));
    }
    if (menuOverlay) {
        menuOverlay.addEventListener("click", () => toggleModal(false));
    }

    // Export function to window so other components can call it
    (window as any).openMenuModal = () => toggleModal(true);
</script>
