                class="font-heading text-[length:clamp(2.8rem,5vw,4.5rem)] text-forest-dark text-center mb-0 leading-[1.1]"
            >
                Sabor & Tradición
            </h2>
        </div>

        <div class="menu-body">
            <!-- Parillas -->
